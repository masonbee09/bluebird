# Backend-specific ignores

# API / runtime logs must never be committed.
api.log
*.log
*.log.*
logs/

# Beta access-key list is a live secret. Keep only the example file in VCS.
beta_keys.json
!beta_keys.example.json

# User feedback store (contains user data — never commit).
feedback.jsonl

# Python caches and build artifacts
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments (common layouts)
.venv/
venv/
env/
.env
.env.*
!.env.example
