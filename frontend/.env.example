# Copy this file to .env (or .env.local) and adjust as needed.
#
# VITE_API_BASE controls the origin the frontend talks to. Leave it unset
# for local development (defaults to http://127.0.0.1:8001). For hosted
# builds, set it at build-time, e.g.:
#
#   VITE_API_BASE=https://api.bluebird.example.com
#
# The /auth/validate endpoint and every solver endpoint live under this base.

VITE_API_BASE=http://127.0.0.1:8001
